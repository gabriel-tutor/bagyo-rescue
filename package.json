{
  "name": "bagyo-rescue",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@bagyo-rescue/web",
    "preview:web": "pnpm --filter=@bagyo-rescue/web preview",
    "test": "turbo run test",
    "test:run": "turbo run test:run",
    "lint": "pnpm exec oxlint -c .oxlintrc.json --quiet .",
    "lint:fix": "pnpm exec oxlint -c .oxlintrc.json --quiet --fix .",
    "format": "pnpm exec oxfmt -c .oxfmtrc.json .",
    "format:check": "pnpm exec oxfmt -c .oxfmtrc.json --check .",
    "check:types": "turbo run check:types",
    "check:spell": "turbo run check:spell",
    "check:all": "pnpm lint && pnpm check:types && pnpm check:spell",
    "clean": "turbo run clean && rm -rf node_modules **/node_modules",
    "db:start": "pnpm -F @bagyo-rescue/prisma db:start",
    "db:stop": "pnpm -F @bagyo-rescue/prisma db:stop",
    "db:pull": "pnpm -F @bagyo-rescue/prisma db:pull",
    "db:deploy": "pnpm -F @bagyo-rescue/prisma db:deploy",
    "db:dev": "pnpm -F @bagyo-rescue/prisma db:dev",
    "db:status": "pnpm -F @bagyo-rescue/prisma db:status",
    "sync:rules": "pnpm dlx tsx tools/context-factory/scripts/sync-rules.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "husky": "^9.1.6",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.20"
  },
  "packageManager": "pnpm@9.1.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.1.1"
  }
}
