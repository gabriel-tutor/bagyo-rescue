datasource db {
  provider = "postgresql"
}

enum RiskLevel {
  LOW      @map("Low")
  MEDIUM   @map("Medium")
  HIGH     @map("High")
  CRITICAL @map("Critical")

  @@map("risk_level")
}

enum HouseStatus {
  NOT_CHECKED      @map("Not Checked")
  SAFE             @map("Safe")
  NEEDS_ASSISTANCE @map("Needs Assistance")
  NEEDS_RESCUE     @map("Needs Rescue")
  EVACUATED        @map("Evacuated")

  @@map("house_status")
}

enum WaterLevel {
  NONE    @map("None")
  ANKLE   @map("Ankle")
  KNEE    @map("Knee")
  WAIST   @map("Waist")
  CHEST   @map("Chest")
  ROOF    @map("Roof")
  UNKNOWN @map("Unknown")

  @@map("water_level")
}

enum Sex {
  MALE              @map("Male")
  FEMALE            @map("Female")
  OTHER             @map("Other")
  PREFER_NOT_TO_SAY @map("Prefer Not To Say")

  @@map("sex")
}

enum ResidentStatus {
  INSIDE_HOUSE           @map("Inside House")
  EVACUATED              @map("Evacuated")
  MISSING_OR_UNCONFIRMED @map("Missing / Unconfirmed")
  NEEDS_RESCUE           @map("Needs Rescue")
  SAFE                   @map("Safe")

  @@map("resident_status")
}

enum ContactEntityType {
  LGU               @map("LGU")
  BARANGAY          @map("Barangay")
  AREA              @map("Area")
  HOUSE             @map("House")
  FAMILY            @map("Family")
  EVACUATION_CENTER @map("Evacuation Center")

  @@map("contact_entity_type")
}

enum ContactRole {
  LGU_ADMIN                @map("LGU Admin")
  MDRRMO_OFFICER           @map("MDRRMO Officer")
  BARANGAY_CAPTAIN         @map("Barangay Captain")
  BARANGAY_SECRETARY       @map("Barangay Secretary")
  RESPONDER                @map("Responder")
  PUROK_LEADER             @map("Purok Leader")
  HOUSEHOLD_REPRESENTATIVE @map("Household Representative")
  FAMILY_HEAD              @map("Family Head")
  RELATIVE                 @map("Relative")
  VOLUNTEER                @map("Volunteer")

  @@map("contact_role")
}

enum EvacuationCenterType {
  SCHOOL           @map("School")
  COVERED_COURT    @map("Covered Court")
  GYMNASIUM        @map("Gymnasium")
  BARANGAY_HALL    @map("Barangay Hall")
  CHURCH           @map("Church")
  COMMUNITY_CENTER @map("Community Center")
  OTHER            @map("Other")

  @@map("evacuation_center_type")
}

enum EvacuationCenterStatus {
  OPEN          @map("Open")
  NEAR_CAPACITY @map("Near Capacity")
  FULL          @map("Full")
  CLOSED        @map("Closed")
  UNAVAILABLE   @map("Unavailable")

  @@map("evacuation_center_status")
}

enum EvacuationAssignmentStatus {
  ASSIGNED               @map("Assigned")
  CHECKED_IN             @map("Checked In")
  TRANSFERRED            @map("Transferred")
  LEFT                   @map("Left")
  MISSING_OR_UNCONFIRMED @map("Missing / Unconfirmed")

  @@map("evacuation_assignment_status")
}

model Lgu {
  id                 String             @id @default(dbgenerated("concat('lgu_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  name               String
  province           String
  cityOrMunicipality String             @map("city_or_municipality")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  barangays          Barangay[]
  evacuationCenters  EvacuationCenter[]

  @@map("lgus")
}

model Barangay {
  id                String             @id @default(dbgenerated("concat('brgy_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  lguId             String             @map("lgu_id")
  name              String
  areaName          String?            @map("area_name")
  riskLevel         RiskLevel          @map("risk_level")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lgu               Lgu                @relation(fields: [lguId], references: [id], onDelete: Cascade)
  houses            House[]
  evacuationCenters EvacuationCenter[]

  @@index([lguId])
  @@map("barangays")
}

model House {
  id            String                       @id @default(dbgenerated("concat('house_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  barangayId    String                       @map("barangay_id")
  houseCode     String                       @unique @map("house_code")
  address       String
  landmark      String?
  latitude      Decimal?                     @db.Decimal(9, 6)
  longitude     Decimal?                     @db.Decimal(9, 6)
  currentStatus HouseStatus                  @default(NOT_CHECKED) @map("current_status")
  waterLevel    WaterLevel                   @default(UNKNOWN) @map("water_level")
  lastCheckedAt DateTime?                    @map("last_checked_at") @db.Timestamptz(6)
  lastCheckedBy String?                      @map("last_checked_by")
  createdAt     DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  barangay      Barangay                     @relation(fields: [barangayId], references: [id], onDelete: Cascade)
  families      Family[]
  assignments   EvacuationCenterAssignment[]

  @@index([barangayId])
  @@index([currentStatus])
  @@index([waterLevel])
  @@map("houses")
}

model Family {
  id                          String                       @id @default(dbgenerated("concat('family_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  houseId                     String                       @map("house_id")
  familyName                  String                       @map("family_name")
  headOfFamily                String                       @map("head_of_family")
  totalMembers                Int                          @default(0) @map("total_members")
  currentInsideCount          Int                          @default(0) @map("current_inside_count")
  evacuatedCount              Int                          @default(0) @map("evacuated_count")
  missingOrUnconfirmedCount   Int                          @default(0) @map("missing_or_unconfirmed_count")
  needsAssistance             Boolean                      @default(false) @map("needs_assistance")
  notes                       String?
  createdAt                   DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  house                       House                        @relation(fields: [houseId], references: [id], onDelete: Cascade)
  residents                   Resident[]
  evacuationCenterAssignments EvacuationCenterAssignment[]

  @@index([houseId])
  @@index([needsAssistance])
  @@map("families")
}

model Resident {
  id            String         @id @default(dbgenerated("concat('resident_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  familyId      String         @map("family_id")
  firstName     String         @map("first_name")
  lastName      String         @map("last_name")
  age           Int?
  sex           Sex
  isSenior      Boolean        @default(false) @map("is_senior")
  isChild       Boolean        @default(false) @map("is_child")
  isPwd         Boolean        @default(false) @map("is_pwd")
  isPregnant    Boolean        @default(false) @map("is_pregnant")
  currentStatus ResidentStatus @default(INSIDE_HOUSE) @map("current_status")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  family        Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([currentStatus])
  @@index([isSenior])
  @@index([isChild])
  @@index([isPwd])
  @@index([isPregnant])
  @@map("residents")
}

model ContactPerson {
  id                     String            @id @default(dbgenerated("concat('cp_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  entityType             ContactEntityType @map("entity_type")
  entityId               String            @map("entity_id")
  fullName               String            @map("full_name")
  role                   ContactRole
  contactNumber          String            @map("contact_number")
  alternateContactNumber String?           @map("alternate_contact_number")
  email                  String?
  isPrimary              Boolean           @default(false) @map("is_primary")
  notes                  String?
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([isPrimary])
  @@map("contact_persons")
}

model EvacuationCenter {
  id                String                       @id @default(dbgenerated("concat('evac_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  lguId             String                       @map("lgu_id")
  barangayId        String?                      @map("barangay_id")
  name              String
  type              EvacuationCenterType         @default(OTHER)
  address           String
  landmark          String?
  latitude          Decimal?                     @db.Decimal(9, 6)
  longitude         Decimal?                     @db.Decimal(9, 6)
  capacity          Int                          @default(0)
  currentOccupancy  Int                          @default(0) @map("current_occupancy")
  status            EvacuationCenterStatus       @default(OPEN)
  hasFoodSupply     Boolean                      @default(false) @map("has_food_supply")
  hasWaterSupply    Boolean                      @default(false) @map("has_water_supply")
  hasMedicalSupport Boolean                      @default(false) @map("has_medical_support")
  hasPower          Boolean                      @default(false) @map("has_power")
  notes             String?
  createdAt         DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lgu               Lgu                          @relation(fields: [lguId], references: [id], onDelete: Cascade)
  barangay          Barangay?                    @relation(fields: [barangayId], references: [id], onDelete: SetNull)
  assignments       EvacuationCenterAssignment[]

  @@index([lguId])
  @@index([barangayId])
  @@index([status])
  @@map("evacuation_centers")
}

model EvacuationCenterAssignment {
  id                 String                     @id @default(dbgenerated("concat('evac_assignment_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  evacuationCenterId String                     @map("evacuation_center_id")
  familyId           String                     @map("family_id")
  houseId            String                     @map("house_id")
  numberOfPeople     Int                        @default(0) @map("number_of_people")
  status             EvacuationAssignmentStatus @default(ASSIGNED)
  arrivedAt          DateTime?                  @map("arrived_at") @db.Timestamptz(6)
  leftAt             DateTime?                  @map("left_at") @db.Timestamptz(6)
  notes              String?
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  evacuationCenter   EvacuationCenter           @relation(fields: [evacuationCenterId], references: [id], onDelete: Cascade)
  family             Family                     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  house              House                      @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@index([evacuationCenterId])
  @@index([familyId])
  @@index([houseId])
  @@index([status])
  @@map("evacuation_center_assignments")
}
